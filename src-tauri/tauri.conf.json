{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iPhoneLabelPrinter",
  "version": "1.0.9",
  "identifier": "com.iphonelabelprinter.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "iPhoneLabelPrinter",
        "width": 1120,
        "height": 740,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; connect-src ipc: http://ipc.localhost https://github.com; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../assets/bin/macos-arm64/": "macos-arm64",
      "../assets/bin/win32/": "win32"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBRkUwREUxN0FDRDc3NDYKUldSR2Q4MTY0UTMrU2w5QjRCdWc4V3RLajdXT0Yyc1h4Z2pZS2Fma3J4a3NpdmxpOVFZcFo0NU4K",
      "endpoints": [
        "https://github.com/DwennK/iPhoneLabelPrinter/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
