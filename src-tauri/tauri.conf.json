{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iPhoneLabelPrinter",
  "version": "0.1.0",
  "identifier": "com.iphonelabelprinter.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "iPhoneLabelPrinter",
        "width": 1120,
        "height": 740,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../assets/bin/win32/*",
      "../history.py",
      "../label_generator.py",
      "../utils.py",
      "../tauri_bridge.py"
    ]
  }
}
